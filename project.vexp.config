name: VEB Project Testing
version: 1.0.0
type: application
author: Codex
contact: local
ask:install:
  - var: install_note
    question: Installation note
    type: w
    default: ready
ask:runtime:
  - var: port
    question: Which port should the sample server use?
    type: w
    default: "4010"
run:install:
  - run: npm install
run:runtime:
  - run: node server.js ${port}